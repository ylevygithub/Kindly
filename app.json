{
  "expo": {
    "name": "Kindly",
    "slug": "kindly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-nwx.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-nwx.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "events148.kapstr.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Kindly utilise tes contacts pour t'aider \u00e0 inviter tes amis.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.events148.kapstr.app.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-nwx.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      ["react-native-purchases"],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-contacts"
    ],
    "scheme": "kindly",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://zauy7bmy2rc7pfput2udb5re8bn4xw88.app.specular.dev",
      "oneSignalAppId": "c8adfe91-1ac9-4c9c-86ba-0f6170a86044",
      "revenueCatApiKeyIos": "appl_REPLACE_WITH_YOUR_IOS_KEY",
      "revenueCatApiKeyAndroid": "goog_REPLACE_WITH_YOUR_ANDROID_KEY",
      "revenueCatEntitlementId": "pro"
    }
  }
}